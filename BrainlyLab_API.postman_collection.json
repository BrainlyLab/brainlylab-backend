	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set base_url for local development",
					"if (!pm.environment.get(\"base_url\")) {\n    pm.environment.set(\"base_url\", \"http://127.0.0.1:8000\");\n}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Extract tokens from login response",
					"if (pm.request.url.includes(\"/api/auth/login/\") && pm.response.code === 200) {\n    const response = pm.response.json();\n    pm.environment.set(\"access_token\", response.access);\n    pm.environment.set(\"refresh_token\", response.refresh);\n    console.log(\"Access Token:\", response.access);\n    console.log(\"Refresh Token:\", response.refresh);\n}"
				]
			}
		}
